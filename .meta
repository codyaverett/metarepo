{
  "ignore": [
    ".git",
    ".vscode",
    "node_modules",
    "target",
    ".DS_Store"
  ],
  "projects": {
    ".claude": "local",
    "meta-core": "local",
    "plugins": "local",
    "fuzz": "local",
    "examples": "local",
    "meta": "local",
    "scripts": "local",
    ".github": "local",
    "metarepo-plugin-sdk": "local",
    "plugins/containers": {
      "url": "git@github.com:codyaverett/metarepo-container.git",
      "aliases": [],
      "scripts": {
        "build": "docker build -t container .",
        "slow": "sleep 1",
        "test": "echo 'Testing container plugin'"
      },
      "env": {},
      "worktree_init": null,
      "bare": null
    },
    "docs": "local"
  },
  "plugins": null,
  "nested": null,
  "aliases": null,
  "scripts": {
    "build": "cargo build --release",
    "slow": "sleep 3",
    "test": "echo 'Global test script'"
  },
  "worktree_init": null,
  "default_bare": true,
  "plugins-integrity": null
}
